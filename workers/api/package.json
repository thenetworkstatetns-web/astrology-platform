{
  "name": "@astro/workers-api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo .wrangler",
    "db:migrate:local": "wrangler d1 migrations apply astro-platform-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply astro-platform-db --remote"
  },
  "dependencies": {
    "@astro/db": "workspace:*",
    "@astro/shared": "workspace:*",
    "@astro/types": "workspace:*",
    "@astro/utils": "workspace:*",
    "hono": "^4.6.5",
    "@hono/zod-validator": "^0.4.1",
    "drizzle-orm": "^0.33.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241004.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.80.0"
  }
}
